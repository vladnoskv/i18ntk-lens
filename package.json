{
  "name": "i18ntk-lens",
  "displayName": "i18ntk Lens",
  "description": "Inline i18ntk translation visibility for VS Code: hovers, CodeLens, missing-key warnings, unused-key diagnostics, and key navigation.",
  "version": "1.1.3",
  "publisher": "VladNoskov",
  "license": "MIT",
  "icon": "media/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/vladnoskv/i18ntk-lens"
  },
  "engines": {
    "vscode": "^1.90.0",
    "node": ">=18.0.0"
  },
  "categories": [
    "Other",
    "Linters"
  ],
  "keywords": [
    "i18ntk",
    "i18n",
    "translation",
    "codelens",
    "hover"
  ],
  "activationEvents": [
    "workspaceContains:locales",
    "workspaceContains:i18n",
    "workspaceContains:translations",
    "workspaceContains:public/locales",
    "workspaceContains:src/locales"
  ],
  "main": "./out/src/extension.js",
  "contributes": {
    "configuration": {
      "title": "i18ntk Lens",
      "properties": {
        "i18ntkLens.localeDirectory": {
          "type": "string",
          "default": "",
          "description": "Locale directory. Empty means auto-detect common locale folders."
        },
        "i18ntkLens.sourceLocale": {
          "type": "string",
          "default": "en",
          "description": "Source/default locale code."
        },
        "i18ntkLens.extensionLanguage": {
          "type": "string",
          "default": "auto",
          "enum": [
            "auto",
            "en",
            "es",
            "fr",
            "de"
          ],
          "enumDescriptions": [
            "Follow the current VS Code display language when supported.",
            "English",
            "Spanish",
            "French",
            "German"
          ],
          "description": "Language used by i18ntk Lens extension UI messages."
        },
        "i18ntkLens.scanOnStartup": {
          "type": "boolean",
          "default": false,
          "description": "Run a workspace scan when i18ntk Lens activates. Disabled by default; use Scan Workspace manually unless you want startup scans."
        },
        "i18ntkLens.autoScanOnSave": {
          "type": "boolean",
          "default": false,
          "description": "Run a debounced workspace scan after an editor document is saved. Disabled by default to reduce CPU and memory usage."
        },
        "i18ntkLens.maxScanFiles": {
          "type": "number",
          "default": 1000,
          "minimum": 100,
          "description": "Maximum source files to scan. Lower values reduce extension-host CPU and memory usage in large workspaces."
        },
        "i18ntkLens.exclude": {
          "type": "array",
          "default": [
            "node_modules",
            ".git",
            ".next",
            "dist",
            "build",
            "coverage"
          ],
          "items": {
            "type": "string"
          },
          "description": "Folder or file name fragments excluded from scans."
        },
        "i18ntkLens.customWrappers": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          },
          "description": "Custom translation wrapper function names (e.g. tx, __, _t)."
        },
        "i18ntkLens.keyFormats": {
          "type": "array",
          "default": [
            "dot",
            "snake"
          ],
          "items": {
            "type": "string",
            "enum": [
              "dot",
              "snake"
            ]
          },
          "description": "Translation key formats to detect and match. Enable dot for keys like news.page.title and snake for keys like news_page_title."
        }
      }
    },
    "commands": [
      {
        "command": "i18ntkLens.scan",
        "title": "i18ntk Lens: Scan Workspace",
        "category": "i18ntk Lens"
      },
      {
        "command": "i18ntkLens.openKeyInLocaleFiles",
        "title": "i18ntk Lens: Open Key in Locale Files",
        "category": "i18ntk Lens"
      },
      {
        "command": "i18ntkLens.addAutoTranslatePlaceholder",
        "title": "i18ntk Lens: Add Key to Auto Translate Protection",
        "category": "i18ntk Lens"
      },
      {
        "command": "i18ntkLens.openSettings",
        "title": "i18ntk Lens: Open Settings",
        "category": "i18ntk Lens"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p . && node scripts/copy-i18ntk-locales.js",
    "test:unit": "node --test out/test/unit/*.test.js",
    "test": "npm run compile && npm run test:unit",
    "package": "vsce package --out ../i18ntk-lens-1.1.3.vsix"
  },
  "dependencies": {
    "i18ntk": "file:../i18ntk-4.4.2.tgz"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/vscode": "^1.90.0",
    "@vscode/vsce": "^3.9.1",
    "typescript": "^5.8.3"
  }
}
